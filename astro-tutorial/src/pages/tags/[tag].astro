---
import { getCollection } from "astro:content";
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../components/BlogPost.astro';

// Defines which dynamic routes Astro should generate.
export async function getStaticPaths() {
    // Get all blog posts from the blogs folder.
    const allPosts = await getCollection("blog");

    // Find every unique tag used across all blog posts.
    const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
    
    // Create a page for each tag and pass only matching posts to that page.
    return uniqueTags.map((tag) => {
        const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));
        return {
            params: { tag },
            props: { posts: filteredPosts },
        };
    });
}

const { tag } = Astro.params; // Gets the current tag value from the URL
const { posts } = Astro.props; // Receive the filtered posts for this tag page.
---

<BaseLayout pageTitle={tag}>
    <p>Posts tagged with {tag}:</p>
    <ul>
        {posts.map((post: any) => <BlogPost url={`/posts/${post.id}/`} title={post.data.title} />)} <!-- Display each post that matches this tag. -->
    </ul>
</BaseLayout>